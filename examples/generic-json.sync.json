{
  "provider": "generic-json",
  "name": "generic-table-demo",
  "read_url": "https://example.com/api/tasks",
  "write_url_template": "https://example.com/api/tasks/{task_key}",
  "write_method": "PATCH",
  "list_field": "items",
  "task_key_field": "id",
  "title_field": "title",
  "detail_field": "detail",
  "status_field": "status",
  "headers": {
    "Authorization": "Bearer ${GENERIC_TABLE_TOKEN}"
  },
  "timeout_seconds": 30
}
